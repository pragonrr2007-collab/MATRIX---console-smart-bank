/* 3. Schedule Future Transaction */
static void schedule_future_transaction(void) {
    banner();
    char typbuf[16];
    read_line_prompt(language ? "தரம் (deposit/withdraw/transfer): " : "Type (deposit/withdraw/transfer): ", typbuf, sizeof typbuf);
    char from[MAX_ACCSTR], to[MAX_ACCSTR];
    read_line_prompt(language ? "From account: " : "From account: ", from, sizeof from);
    int idx_from = find_account(from);
    if (idx_from == -1) { printf("%s\n", language ? "அனுப்புநர் இல்லை." : "Sender not found."); return; }
    /* require PIN+OTP for scheduling on that account */
    if (!verify_pin_and_otp_for_index(idx_from)) return;
    double amt;
    char amtbuf[64];
    read_line_prompt(language ? "தொகை: " : "Amount: ", amtbuf, sizeof amtbuf); amt = atof(amtbuf);
    if (amt <= 0.0) { printf("%s\n", language ? "தவறான தொகை." : "Invalid amount."); return; }
    to[0] = 0;
    if (strcasecmp(typbuf,"transfer")==0) {
        read_line_prompt(language ? "To account: " : "To account: ", to, sizeof to);
        if (find_account(to) == -1) { printf("%s\n", language ? "பெறுநர் கிடையாது." : "Receiver not found."); return; }
    }
    char dt[64];
    read_line_prompt(language ? "நாள்/நேரம் (YYYY-MM-DD HH:MM:SS): " : "Enter date/time (YYYY-MM-DD HH:MM:SS): ", dt, sizeof dt);
    struct tm tmv; memset(&tmv,0,sizeof tmv);
    if (sscanf(dt, "%d-%d-%d %d:%d:%d", &tmv.tm_year, &tmv.tm_mon, &tmv.tm_mday, &tmv.tm_hour, &tmv.tm_min, &tmv.tm_sec) < 3) {
        printf("%s\n", language ? "தவறான தேதி." : "Bad date format."); return;
    }
    /* convert: note tm_year currently has year not year-1900 */
    tmv.tm_year -= 1900; tmv.tm_mon -= 1; tmv.tm_isdst = -1;
    time_t sch = mktime(&tmv);
    if (sch == (time_t)-1 || sch <= time(NULL)) { printf("%s\n", language ? "எதிர்கால தேதியை கொடுக்கவும்." : "Provide future date."); return; }
    Transaction tx; memset(&tx,0,sizeof tx);
    if (strcasecmp(typbuf,"deposit")==0) tx.type = TX_DEPOSIT;
    else if (strcasecmp(typbuf,"withdraw")==0) tx.type = TX_WITHDRAW;
    else tx.type = TX_TRANSFER;
    strncpy(tx.from, from, sizeof tx.from-1);
    if (to[0]) strncpy(tx.to, to, sizeof tx.to-1);
    tx.amount = amt;
    tx.fee = SERVICE_CHARGE + SMS_COST + PRE_SCHEDULE_COST;
    tx.is_scheduled = 1;
    tx.scheduled_for = sch;
    tx.when = time(NULL);
    record_tx(&tx);
    printf("%s\n", language ? "பரிவர்த்தனை திட்டமிடப்பட்டது." : "Transaction scheduled.");
}

/* 4. Cancel Scheduled Transaction */
static void cancel_scheduled_transaction(void) {
    banner();
    if (count_tx==0) { printf("%s\n", language ? "பரிவர்தனைகள் இல்லை." : "No transactions."); return; }
    char acc[MAX_ACCSTR];
    read_line_prompt(language ? "உங்கள் கணக்கு எண்: " : "Your account number: ", acc, sizeof acc);
    int idx_acc = find_account(acc);
    if (idx_acc == -1) { printf("%s\n", language ? "கணக்கு இல்லை." : "Account not found."); return; }
    /* require PIN+OTP */
    if (!verify_pin_and_otp_for_index(idx_acc)) return;
    /* list scheduled transactions for this account */
    int found = 0;
    for (int i=0;i<count_tx;++i) {
        Transaction *tx = &transactions[i];
        if (tx->is_scheduled && strcmp(tx->from, acc)==0) {
            char sf[32]; format_time(tx->scheduled_for, sf, sizeof sf);
            printf("Index %d | Type:%d | To:%s | Amt:%.2f | Sch:%s\n", i, tx->type, tx->to[0]?tx->to:"-", tx->amount, sf);
            found = 1;
        }
    }
    if (!found) { printf("%s\n", language ? "முன்நியமிக்கப்பட்ட பரிவர்த்தனை இல்லை." : "No scheduled transactions."); return; }
    char idxbuf[32];
    read_line_prompt(language ? "அடைந்ததி எண்ணை உள்ளிடுக (Index): " : "Enter index to cancel: ", idxbuf, sizeof idxbuf);
    int ix = atoi(idxbuf);
    if (ix < 0 || ix >= count_tx || !transactions[ix].is_scheduled) { printf("%s\n", language ? "தவறான குறியீடு." : "Invalid index."); return; }
    transactions[ix].is_scheduled = 0;
    transactions[ix].scheduled_for = 0;
    save_transactions_to_disk();
    printf("%s\n", language ? "நியமிப்பு ரத்து செய்யப்பட்டு உள்ளது." : "Scheduled transaction cancelled.");
}

