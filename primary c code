/* 9. Smart Balance Calculator (AI-ish) */
static void smart_balance_calculator(void) {
    banner();
    char acc[MAX_ACCSTR];
    read_line_prompt(language ? "கணக்கு எண்: " : "Enter account number: ", acc, sizeof acc);
    int idx = find_account(acc);
    if (idx == -1) { printf("%s\n", language ? "கணக்கு இல்லை." : "Account not found."); return; }
    char dt[64];
    read_line_prompt(language ? "நாள்/நேரம் (YYYY-MM-DD HH:MM:SS): " : "Enter date/time (YYYY-MM-DD HH:MM:SS): ", dt, sizeof dt);
    struct tm tmv; memset(&tmv,0,sizeof tmv);
    if (sscanf(dt, "%d-%d-%d %d:%d:%d", &tmv.tm_year, &tmv.tm_mon, &tmv.tm_mday, &tmv.tm_hour, &tmv.tm_min, &tmv.tm_sec) < 3) {
        printf("%s\n", language ? "தவறான தேதி." : "Bad date format."); return;
    }
    tmv.tm_year -= 1900; tmv.tm_mon -= 1; tmv.tm_isdst = -1;
    time_t target = mktime(&tmv);
    if (target == (time_t)-1) { printf("%s\n", language ? "தவறான தேதி." : "Bad date."); return; }
    double current = accounts[idx].bal;
    double scheduled_deposits = 0.0, scheduled_withdrawals = 0.0;
    int scheduled_count = 0;
    for (int i=0;i<count_tx;++i) {
        Transaction *tx = &transactions[i];
        if (!tx->is_scheduled) continue;
        if (tx->scheduled_for <= target) {
            ++scheduled_count;
            if (strcmp(tx->from, accounts[idx].acc)==0) {
                if (tx->type==TX_DEPOSIT) scheduled_deposits += (tx->amount - tx->fee);
                else if (tx->type==TX_WITHDRAW) scheduled_withdrawals += (tx->amount + tx->fee);
                else if (tx->type==TX_TRANSFER) scheduled_withdrawals += (tx->amount + tx->fee);
            }
            if (tx->type==TX_TRANSFER && strcmp(tx->to, accounts[idx].acc)==0) scheduled_deposits += tx->amount;
        }
    }
    double sms_tax = scheduled_count * SMS_COST;
    double predicted = current + scheduled_deposits - scheduled_withdrawals - sms_tax;
    /* small ML-like tweak: average recent daily net */
    double ml_adj = 0.0;
    time_t now = time(NULL);
    time_t weekago = now - 7*24*3600;
    double sum_net = 0; int cnt=0;
    for (int i=0;i<count_tx;++i) {
        Transaction *tx = &transactions[i];
        if (tx->when >= weekago && tx->when <= now) {
            if (strcmp(tx->from, accounts[idx].acc)==0) {
                if (tx->type==TX_DEPOSIT) sum_net += (tx->amount - tx->fee);
                else sum_net -= (tx->amount + tx->fee);
            }
            if (tx->type==TX_TRANSFER && strcmp(tx->to, accounts[idx].acc)==0) sum_net += tx->amount;
            ++cnt;
        }
    }
    if (cnt>0) ml_adj = (sum_net / cnt) * 0.1;
    printf("%s\n", language ? "---- Smart Balance Calculator ----" : "---- Smart Balance Calculator ----");
    printf("%s: %s\n", language ? "Account" : "Account", accounts[idx].acc);
    printf("%s: %.2f\n", language ? "Current balance" : "Current balance", current);
    printf("%s: %.2f\n", language ? "Scheduled deposits (<=target)" : "Scheduled deposits (<=target)", scheduled_deposits);
    printf("%s: %.2f\n", language ? "Scheduled withdrawals" : "Scheduled withdrawals", scheduled_withdrawals);
    printf("%s: %.2f\n", language ? "SMS / Service tax (est.)" : "SMS / Service tax (est.)", sms_tax);
    printf("%s: %.2f\n", language ? "ML Adjustment (small)" : "ML Adjustment (small)", ml_adj);
    printf("%s: %.2f\n", language ? "Predicted balance (net)" : "Predicted balance (net)", predicted + ml_adj);
}

/* 10. Balance Predictor (ML-like) */
static void balance_predictor_ml(void) {
    banner();
    char acc[MAX_ACCSTR];
    read_line_prompt(language ? "கணக்கு எண்: " : "Enter account number: ", acc, sizeof acc);
    int idx = find_account(acc); if (idx==-1) { printf("%s\n", language ? "கணக்கு இல்லை." : "Account not found."); return; }
    double total_dep=0, total_wd=0; int cnt_dep=0, cnt_wd=0;
    for (int i=0;i<count_tx;++i) {
        Transaction *tx = &transactions[i];
        if (strcmp(tx->from, accounts[idx].acc)==0) {
            if (tx->type==TX_DEPOSIT) { total_dep += tx->amount; cnt_dep++; }
            else if (tx->type==TX_WITHDRAW) { total_wd += tx->amount; cnt_wd++; }
            else if (tx->type==TX_TRANSFER) { total_wd += tx->amount; cnt_wd++; }
        }
        if (tx->type==TX_TRANSFER && strcmp(tx->to, accounts[idx].acc)==0) { total_dep += tx->amount; cnt_dep++; }
    }
    double avg_dep = cnt_dep ? total_dep / cnt_dep : 0;
    double avg_wd  = cnt_wd ? total_wd / cnt_wd : 0;
    double expected_change = (avg_dep - avg_wd) * 0.7;
    double predicted_next = accounts[idx].bal + expected_change;
    double confidence = 50.0;
    if (cnt_dep + cnt_wd > 20) confidence = 85.0;
    else if (cnt_dep + cnt_wd > 5) confidence = 65.0;
    printf("%s\n", language ? "---- Balance Predictor (ML) ----" : "---- Balance Predictor (ML) ----");
    printf("Avg deposit: %.2f | Avg withdraw: %.2f\n", avg_dep, avg_wd);
    printf("Expected net change: %.2f\n", expected_change);
    printf("Predicted next balance: %.2f\n", predicted_next);
    printf("Confidence: %.1f%%\n", confidence);
}

