#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <ctype.h>
#include <strings.h> /* for strcasecmp on POSIX */

#define MAX_ACCOUNTS 200
#define MAX_NAME 80
#define MAX_ACCSTR 32
#define MAX_TX 20000

/* Fees */
#define SERVICE_CHARGE 1.00
#define SMS_COST 0.50
#define OTP_COST 0.10
#define PRE_SCHEDULE_COST 0.50

typedef enum { TX_DEPOSIT=0, TX_WITHDRAW=1, TX_TRANSFER=2 } TxType;

typedef struct {
    TxType type;
    char from[MAX_ACCSTR];
    char to[MAX_ACCSTR];
    double amount;
    double fee;
    int is_scheduled;       /* 0 or 1 */
    time_t scheduled_for;   /* 0 if not scheduled */
    time_t when;            /* execution/creation time */
} Transaction;

typedef struct {
    char acc[MAX_ACCSTR];
    char name[MAX_NAME];
    int pin;
    double bal;
} Account;

/* Globals */
static Account accounts[MAX_ACCOUNTS];
static int count_acc = 0;
static Transaction transactions[MAX_TX];
static int count_tx = 0;
static int language = 0; /* 0 English, 1 Tamil */

/* Simple utilities */
static void flush_stdin(void) {
    int c;
    while ((c = getchar()) != '\n' && c != EOF) { }
}

/* safe read line */
static void read_line_prompt(const char *prompt, char *buf, size_t n) {
    if (prompt) fputs(prompt, stdout);
    if (!fgets(buf, (int)n, stdin)) { buf[0]=0; return; }
    buf[strcspn(buf, "\r\n")] = 0;
}

/* format time */
static void format_time(time_t t, char *out, size_t n) {
    if (t == 0) { snprintf(out,n,"N/A"); return; }
    struct tm tmv;
#if defined(__unix__) || defined(__linux__) || defined(__APPLE__) || defined(__MACH__)
    localtime_r(&t,&tmv);
#else
    { struct tm *p = localtime(&t); if (p) tmv = *p; else memset(&tmv,0,sizeof tmv); }
#endif
    strftime(out,n,"%Y-%m-%d %H:%M:%S",&tmv);
}

/* Persistence helpers (basic) */
static int save_accounts_to_disk(void) {
    FILE *f = fopen("accounts.dat","wb");
    if (!f) return 0;
    if (fwrite(&count_acc, sizeof(count_acc), 1, f) != 1) { fclose(f); return 0; }
    if (count_acc > 0) {
        if (fwrite(accounts, sizeof(Account), count_acc, f) != (size_t)count_acc) { fclose(f); return 0; }
    }
    fclose(f);
    return 1;
}
static int load_accounts_from_disk(void) {
    FILE *f = fopen("accounts.dat","rb");
    if (!f) { count_acc = 0; return 0; }
    if (fread(&count_acc, sizeof(count_acc), 1, f) != 1) { fclose(f); count_acc = 0; return 0; }
    if (count_acc > 0) {
        if (fread(accounts, sizeof(Account), count_acc, f) != (size_t)count_acc) { fclose(f); count_acc=0; return 0; }
    }
    fclose(f);
    return 1;
}
static int save_transactions_to_disk(void) {
    FILE *f = fopen("transactions.dat","wb");
    if (!f) return 0;
    if (fwrite(&count_tx, sizeof(count_tx), 1, f) != 1) { fclose(f); return 0; }
    if (count_tx > 0) {
        if (fwrite(transactions, sizeof(Transaction), count_tx, f) != (size_t)count_tx) { fclose(f); return 0; }
    }
    fclose(f);
    return 1;
}
static int load_transactions_from_disk(void) {
    FILE *f = fopen("transactions.dat","rb");
    if (!f) { count_tx = 0; return 0; }
    if (fread(&count_tx, sizeof(count_tx), 1, f) != 1) { fclose(f); count_tx = 0; return 0; }
    if (count_tx > 0) {
        if (fread(transactions, sizeof(Transaction), count_tx, f) != (size_t)count_tx) { fclose(f); count_tx=0; return 0; }
    }
    fclose(f);
    return 1;
}

/* Logging helper */
static void append_log(const Transaction *tx) {
    FILE *f = fopen("transactions.log","a");
    if (!f) return;
    char when_s[64]; format_time(tx->when, when_s, sizeof when_s);
    const char *tstr = tx->type==TX_DEPOSIT ? "DEPOSIT" : tx->type==TX_WITHDRAW ? "WITHDRAW" : "TRANSFER";
    fprintf(f,"[%s] %s | From:%s | To:%s | Amt:%.2f | Fee:%.2f | Sch:%d | SchFor:%ld\n",
            when_s, tstr, tx->from, tx->to[0]?tx->to:"-", tx->amount, tx->fee, tx->is_scheduled, (long)tx->scheduled_for);
    fclose(f);
}

/* helpers to find account index */
static int find_account(const char *acc) {
    for (int i=0;i<count_acc;++i) if (strcmp(accounts[i].acc, acc)==0) return i;
    return -1;
}

/* record transaction */
static void record_tx(const Transaction *tx) {
    if (count_tx < MAX_TX) transactions[count_tx++] = *tx;
    append_log(tx);
    save_transactions_to_disk();
}

/* OTP generator (seeded in main) */
static int generate_otp(void) {
    return rand() % 900000 + 100000; /* 6-digit */
}

/* verify pin + otp */
static int verify_pin_and_otp_for_index(int idx) {
    char buf[64];
    read_line_prompt(language ? "PIN: " : "Enter PIN: ", buf, sizeof buf);
    int entered = atoi(buf);
    if (accounts[idx].pin != entered) {
        printf("%s\n", language ? "தவறான PIN." : "Wrong PIN.");
        return 0;
    }
    int code = generate_otp();
    printf(language ? "OTP: %06d\n" : "OTP: %06d\n", code);
    char otpbuf[64];
    read_line_prompt(language ? "OTP ஐ உள்ளிடவும்: " : "Enter OTP: ", otpbuf, sizeof otpbuf);
    if (atoi(otpbuf) != code) {
        printf("%s\n", language ? "OTP தவறானது." : "OTP incorrect.");
        return 0;
    }
    return 1;
}

