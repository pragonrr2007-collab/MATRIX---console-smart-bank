/* 6. Delete Account */
static void delete_account(void) {
    banner();
    char acc[MAX_ACCSTR];
    read_line_prompt(language ? "அழிக்க வேண்டிய கணக்கு எண்: " : "Account to delete: ", acc, sizeof acc);
    int idx = find_account(acc);
    if (idx == -1) { printf("%s\n", language ? "கணக்கு இல்லை." : "Account not found."); return; }
    /* require PIN + OTP */
    if (!verify_pin_and_otp_for_index(idx)) return;
    /* remove account by shifting array */
    for (int i=idx;i<count_acc-1;++i) accounts[i] = accounts[i+1];
    --count_acc;
    /* remove transactions referencing it (simple approach: mark from/to to empty) */
    for (int i=0;i<count_tx;++i) {
        if (strcmp(transactions[i].from, acc)==0) transactions[i].from[0] = 0;
        if (strcmp(transactions[i].to, acc)==0) transactions[i].to[0] = 0;
    }
    save_accounts_to_disk();
    save_transactions_to_disk();
    printf("%s\n", language ? "கணக்கு நீக்கப்பட்டது." : "Account deleted.");
}

