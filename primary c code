/* Core features */

/* create account */
static void create_account(void) {
    banner();
    if (count_acc >= MAX_ACCOUNTS) { printf("Storage full.\n"); return; }
    char accnum[MAX_ACCSTR];
    read_line_prompt(language ? "கணக்கு எண்: " : "Enter account number: ", accnum, sizeof accnum);
    if (find_account(accnum) != -1) { printf("%s\n", language ? "கணக்கு ஏற்கனவே உள்ளது." : "Account already exists."); return; }
    Account a;
    memset(&a,0,sizeof a);
    strncpy(a.acc, accnum, sizeof a.acc-1);
    read_line_prompt(language ? "பெயர்: " : "Enter name: ", a.name, sizeof a.name);
    char pinbuf[64];
    read_line_prompt(language ? "PIN (numbers): " : "Set PIN (numbers): ", pinbuf, sizeof pinbuf);
    a.pin = atoi(pinbuf);
    char balbuf[64];
    read_line_prompt(language ? "ஆரம்ப இருப்பு: " : "Enter initial balance: ", balbuf, sizeof balbuf);
    a.bal = atof(balbuf);
    accounts[count_acc++] = a;
    save_accounts_to_disk();
    Transaction tx; memset(&tx,0,sizeof tx);
    tx.type = TX_DEPOSIT; strncpy(tx.from, a.acc, sizeof tx.from-1); tx.amount = a.bal; tx.fee = 0.0; tx.when = time(NULL); tx.is_scheduled = 0;
    record_tx(&tx);
    printf("%s\n", language ? "கணக்கு வெற்றிகரமாக உருவாக்கப்பட்டது." : "Account created successfully.");
}

/* deposit or withdraw */
static void deposit_or_withdraw(int is_withdraw) {
    banner();
    if (count_acc == 0) { printf("%s\n", language ? "தற்போது கணக்குகள் எதுவும் இல்லை." : "There are currently no accounts."); return; }
    char accnum[MAX_ACCSTR];
    read_line_prompt(is_withdraw ? (language?"பணம் எடுக்க வேண்டிய கணக்கு: ":"Account to withdraw from: ") : (language?"வைப்பு கணக்கு: ":"Account to deposit to: "), accnum, sizeof accnum);
    int idx = find_account(accnum);
    if (idx == -1) { printf("%s\n", language ? "கணக்கு கிடையாது." : "Account not found."); return; }
    if (!verify_pin_and_otp_for_index(idx)) return;
    char amtbuf[64]; read_line_prompt(is_withdraw ? (language?"எடுத்தல் தொகை: ":"Enter withdrawal amount: ") : (language?"வைப்பு தொகை: ":"Enter deposit amount: "), amtbuf, sizeof amtbuf);
    double amt = atof(amtbuf);
    if (amt <= 0.0) { printf("%s\n", language ? "தவறான தொகை." : "Invalid amount."); return; }
    Transaction tx; memset(&tx,0,sizeof tx);
    tx.type = is_withdraw ? TX_WITHDRAW : TX_DEPOSIT;
    strncpy(tx.from, accnum, sizeof tx.from-1);
    tx.amount = amt;
    tx.fee = SERVICE_CHARGE + SMS_COST + OTP_COST;
    tx.is_scheduled = 0;
    tx.when = time(NULL);
    if (is_withdraw) {
        if (accounts[idx].bal < (amt + tx.fee)) { printf("%s\n", language ? "போதுமான இருப்பு இல்லை." : "Insufficient balance."); return; }
        accounts[idx].bal -= (amt + tx.fee);
    } else {
        accounts[idx].bal += (amt - tx.fee);
    }
    record_tx(&tx);
    save_accounts_to_disk();
    printf("%s %.2f\n", language ? "பரிவர்த்தனை வெற்றி. கட்டணம்:" : "Transaction successful. Fee:", tx.fee);
}

/* transfer */
static void transfer_flow(void) {
    banner();
    if (count_acc < 2) { printf("%s\n", language ? "போதுமான கணக்குகள் இல்லை." : "Not enough accounts to transfer."); return; }
    char from[MAX_ACCSTR], to[MAX_ACCSTR];
    read_line_prompt(language ? "அனுப்புநர் கணக்கு: " : "Sender account: ", from, sizeof from);
    int i_from = find_account(from);
    if (i_from == -1) { printf("%s\n", language ? "அனுப்புநர் கிடையாது." : "Sender not found."); return; }
    if (!verify_pin_and_otp_for_index(i_from)) return;
    read_line_prompt(language ? "பெறுநர் கணக்கு: " : "Receiver account: ", to, sizeof to);
    int i_to = find_account(to);
    if (i_to == -1) { printf("%s\n", language ? "பெறுநர் கிடைக்கவில்லை." : "Receiver not found."); return; }
    char amtbuf[64]; read_line_prompt(language ? "மாற்றத் தொகை: " : "Enter transfer amount: ", amtbuf, sizeof amtbuf);
    double amt = atof(amtbuf);
    if (amt <= 0.0) { printf("%s\n", language ? "தவறான தொகை." : "Invalid amount."); return; }
    Transaction tx; memset(&tx,0,sizeof tx);
    tx.type = TX_TRANSFER; strncpy(tx.from, from, sizeof tx.from-1); strncpy(tx.to, to, sizeof tx.to-1);
    tx.amount = amt; tx.fee = SERVICE_CHARGE + SMS_COST + OTP_COST; tx.is_scheduled = 0; tx.when = time(NULL);
    if (accounts[i_from].bal < (amt + tx.fee)) { printf("%s\n", language ? "அனுப்புநரிடம் போதுமான இருப்பு இல்லை." : "Sender has insufficient balance."); return; }
    accounts[i_from].bal -= (amt + tx.fee); accounts[i_to].bal += amt;
    record_tx(&tx);
    save_accounts_to_disk();
    printf("%s %.2f\n", language ? "பரிமாற்றம் வெற்றி. கட்டணம்:" : "Transfer successful. Fee:", tx.fee);
}

