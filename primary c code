/* show history (all or specific account) */
static void show_history(void) {
    banner();
    if (count_tx==0) { printf("%s\n", language ? "பரிவர்த்தனை பதிவுகள் இல்லை." : "No transactions recorded."); return; }
    char acc[MAX_ACCSTR];
    read_line_prompt(language ? "கணக்கு (அல்லது Enter அனைத்து): " : "Enter account (or Enter for all): ", acc, sizeof acc);
    int filter = acc[0] != '\0';
    puts("+----+------------+----------------+------------+-----------+-----------+---------------------+");
    printf("| %-2s | %-10s | %-14s | %-10s | %-9s | %-9s | %-19s |\n", "No", "Type", language ? "Account" : "Account", language ? "To" : "To", "Amount", "Fee", language ? "When" : "When");
    puts("+----+------------+----------------+------------+-----------+-----------+---------------------+");
    int idx=0;
    for (int i=0;i<count_tx;++i) {
        Transaction *tx = &transactions[i];
        if (filter && strcmp(tx->from, acc)!=0 && (tx->to[0]==0 || strcmp(tx->to, acc)!=0)) continue;
        char when_s[32]; format_time(tx->when, when_s, sizeof when_s);
        const char *tstr = tx->type==TX_DEPOSIT ? (language?"வைப்பு":"DEPOSIT") : tx->type==TX_WITHDRAW ? (language?"பணம் எடு":"WITHDRAW") : (language?"பரிமாற்றம்":"TRANSFER");
        printf("| %2d | %-10s | %-14s | %-10s | %9.2f | %9.2f | %-19s |\n", ++idx, tstr, tx->from, tx->to[0]?tx->to:"-", tx->amount, tx->fee, when_s);
    }
    puts("+----+------------+----------------+------------+-----------+-----------+---------------------+");
    if (idx==0) printf("%s\n", language ? "பொருத்தமான பதிவுகள் இல்லை." : "No matching records.");
}

